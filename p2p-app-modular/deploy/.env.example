# Copy to .env in this directory and fill in real values. Never commit .env.

# Public hostname of the app (DNS A record must point to this server)
DOMAIN=p2p.yourcompany.com

# Email for Let's Encrypt certificate expiry notices
ACME_EMAIL=it@yourcompany.com

# REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET=

# REQUIRED. Password for the bundled PostgreSQL database.
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# Licensed modules for this installation (the commercial "license key").
#   all                    → every module (default)
#   tax,payments,vendor_portal  → same as all, spelled out
#   tax,payments           → no vendor portal
#   (empty)                → core only: PR/PO/GRN, invoices, approvals, vendors
MODULES=all

# Optional: office/VPN IP ranges allowed to reach the staff app (comma-separated CIDRs).
# Used by the staff-allowlist middleware in docker-compose.yml (uncomment those labels).
# STAFF_ALLOWED_IPS=203.0.113.0/24,198.51.100.7/32

# Email notifications (optional — without SMTP_HOST, notifications are only
# recorded in the outbox visible under Settings). Point at your mail server:
# SMTP_HOST=smtp.yourcompany.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=p2p@yourcompany.com
# SMTP_PASS=
# SMTP_FROM=P2P Manager <p2p@yourcompany.com>
# Public URL used in email links (defaults to http://localhost:3000):
# APP_URL=https://p2p.yourcompany.com

# Set to 1 ONLY when serving plain HTTP directly / behind a proxy that does not
# terminate TLS (e.g. Traefik removed, port published directly). Otherwise the
# browser upgrades /css and /js to https:// and the app loads unstyled + blank.
# Leave unset for the default HTTPS-behind-Traefik deployment.
# INSECURE_HTTP=1
